{
    "version": 2,
    "builds": [
        {
            "src": "backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/next"
        }
    ],
    "routes": [
        {
            "src": "/(basic-info|projects|experiences|skills|hobbies|health|register|token|admin)",
            "dest": "backend/main.py"
        },
        {
            "src": "/static/(.*)",
            "dest": "backend/main.py"
        },
        {
            "src": "/(.*)",
            "dest": "/"
        }
    ]
}